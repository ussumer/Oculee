# Base route (compatible with old LLM_* config)
LLM_API_KEY=

# OpenAI-compatible API endpoint (full URL)
# e.g. https://api.openai.com/v1/chat/completions
#      https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_API_URL=https://api.openai.com/v1/chat/completions

# Optional
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=5000
LLM_MAX_OUTPUT_TOKENS=180
LLM_TEMPERATURE=1.1
DEBUG_LLM=0

# Primary route override (optional)
# If set, PRIMARY_* takes precedence over LLM_* for the primary call.
# PRIMARY_LLM_API_KEY=
# PRIMARY_LLM_API_URL=https://api.openai.com/v1/chat/completions
# PRIMARY_LLM_MODEL=gpt-4o-mini
# PRIMARY_LLM_TIMEOUT_MS=5000
# PRIMARY_LLM_MAX_OUTPUT_TOKENS=180
# PRIMARY_LLM_TEMPERATURE=1.1

# Flash fallback route (optional, text-only on primary failure)
# If FLASH_LLM_API_KEY is empty, Flash route is skipped and local fallback is used.
# FLASH_LLM_API_KEY=
# FLASH_LLM_API_URL=https://api.openai.com/v1/chat/completions
# FLASH_LLM_MODEL=gpt-4o-mini
# FLASH_LLM_TIMEOUT_MS=5000
# FLASH_LLM_MAX_OUTPUT_TOKENS=180
# FLASH_LLM_TEMPERATURE=1.1

# Multimodal capture
MULTIMODAL_ENABLED=1
MULTIMODAL_IMAGE_MAX_SIDE=720
MULTIMODAL_IMAGE_MAX_BYTES=180000
MULTIMODAL_IMAGE_CODEC=jpeg
MULTIMODAL_JPEG_QUALITY=72
# MULTIMODAL_CAPTURE_MODE=foreground
# MULTIMODAL_SCREEN_ID=1
